<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <ImageView
            android:id="@+id/cropImage"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            android:src="@drawable/card_background"/>

        <TextView
            android:id="@+id/cropName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:padding="16dp"/>

        <!-- Basic Information Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="12dp"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Basic Information"
                android:textSize="18sp"
                android:textStyle="bold"
                android:padding="8dp"/>

            <TextView
                android:id="@+id/soilType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="4dp"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/temperature"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="4dp"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/fertilizer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="4dp"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/duration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="4dp"
                android:textSize="16sp"/>
        </LinearLayout>

        <!-- STEP 1: PRE-SOWING Card -->
        <LinearLayout
            android:id="@+id/preSowingLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="12dp"
            android:layout_marginTop="8dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="STEP 1: PRE-SOWING (THE FOUNDATION)"
                android:textSize="16sp"
                android:textStyle="bold"
                android:padding="8dp"
                android:background="#4CAF50"
                android:textColor="#FFFFFF"/>

            <TextView
                android:id="@+id/soilTypeDetailed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="4dp"
                android:textSize="15sp"/>

            <TextView
                android:id="@+id/phRange"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="4dp"
                android:textSize="15sp"/>

            <TextView
                android:id="@+id/basalDose"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="4dp"
                android:textSize="15sp"/>

            <TextView
                android:id="@+id/climate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="4dp"
                android:textSize="15sp"/>
        </LinearLayout>

        <!-- STEP 2: SOWING MANAGEMENT Card -->
        <LinearLayout
            android:id="@+id/sowingLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="12dp"
            android:layout_marginTop="8dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="STEP 2: SOWING MANAGEMENT (THE PROTOCOL)"
                android:textSize="16sp"
                android:textStyle="bold"
                android:padding="8dp"
                android:background="#FF9800"
                android:textColor="#FFFFFF"/>

            <TextView
                android:id="@+id/sowingWindow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="4dp"
                android:textSize="15sp"/>

            <TextView
                android:id="@+id/seedRate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="4dp"
                android:textSize="15sp"/>

            <TextView
                android:id="@+id/spacing"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="4dp"
                android:textSize="15sp"/>

            <TextView
                android:id="@+id/seedTreatment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="4dp"
                android:textSize="15sp"/>
        </LinearLayout>

        <!-- STEP 3: NUTRIENT & WATER SCHEDULE Card -->
        <LinearLayout
            android:id="@+id/nutrientLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="12dp"
            android:layout_marginTop="8dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="STEP 3: NUTRIENT and WATER SCHEDULE (THE TIMELINE)"
                android:textSize="16sp"
                android:textStyle="bold"
                android:padding="8dp"
                android:background="#2196F3"
                android:textColor="#FFFFFF"/>

            <TextView
                android:id="@+id/fertilizerSplit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="4dp"
                android:textSize="15sp"/>

            <TextView
                android:id="@+id/irrigationPoints"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="4dp"
                android:textSize="15sp"/>

            <TextView
                android:id="@+id/micronutrients"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="4dp"
                android:textSize="15sp"/>
        </LinearLayout>

        <!-- STEP 4: CROP PROTECTION Card -->
        <LinearLayout
            android:id="@+id/protectionLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="12dp"
            android:layout_marginTop="8dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="STEP 4: CROP PROTECTION (THE DIAGNOSTICS)"
                android:textSize="16sp"
                android:textStyle="bold"
                android:padding="8dp"
                android:background="#F44336"
                android:textColor="#FFFFFF"/>

            <TextView
                android:id="@+id/pestName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="4dp"
                android:textSize="15sp"/>

            <TextView
                android:id="@+id/visualSymptoms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="4dp"
                android:textSize="15sp"/>

            <TextView
                android:id="@+id/chemicalSolution"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="4dp"
                android:textSize="15sp"/>
        </LinearLayout>

        <!-- STEP 5: STORAGE Card -->
        <LinearLayout
            android:id="@+id/storageLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="12dp"
            android:layout_marginTop="8dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="STEP 5: STORAGE (THE FINANCIAL SHIELD)"
                android:textSize="16sp"
                android:textStyle="bold"
                android:padding="8dp"
                android:background="#9C27B0"
                android:textColor="#FFFFFF"/>

            <TextView
                android:id="@+id/harvestMoisture"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="4dp"
                android:textSize="15sp"/>

            <TextView
                android:id="@+id/storageTemp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="4dp"
                android:textSize="15sp"/>

            <TextView
                android:id="@+id/relativeHumidity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="4dp"
                android:textSize="15sp"/>

            <TextView
                android:id="@+id/bagging"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="4dp"
                android:textSize="15sp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>